{
  "name": "fitgen-ai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "start:render": "node scripts/render-bootstrap.mjs && next start -H 0.0.0.0 -p ${PORT:-3000}",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky || true",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:import-wger": "tsx prisma/import-wger.ts",
    "db:enrich": "npm run db:seed && npm run db:import-wger",
    "db:setup": "prisma db push && npm run db:enrich",
    "db:generate": "prisma generate",
    "postinstall": "prisma generate"
  },
  "engines": {
    "node": ">=20.18.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md,yml,yaml,mdc}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@cursor/sdk": "^1.0.23",
    "@mediapipe/tasks-vision": "^0.10.35",
    "@prisma/client": "^5.22.0",
    "@reduxjs/toolkit": "^2.11.2",
    "next": "16.2.1",
    "prisma": "^5.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-redux": "^9.2.0",
    "uuid": "^14.0.1",
    "zod": "^4.4.3",
    "tsx": "^4.23.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "ignore-loader": "^0.1.2",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "tailwindcss": "^4",
    "typescript": "^5.9.3"
  }
}
