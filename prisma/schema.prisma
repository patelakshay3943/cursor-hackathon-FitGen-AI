generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PlanDayStatus {
  locked
  generating
  ready
  completed
}

model Exercise {
  id               String   @id
  name             String
  force            String?
  level            String
  mechanic         String?
  equipment        String?
  category         String
  primaryMuscles   Json
  secondaryMuscles Json
  instructions     Json
  images           Json
  /// Normalized primary muscle group for filtering (e.g. chest, back, legs)
  muscleGroup      String?
  /// Search aliases / alternate names
  aliases          Json     @default("[]")
  /// Free-form tags: compound, isolation, push, pull, home-friendly, etc.
  tags             Json     @default("[]")
  /// free-exercise-db | wger
  source           String   @default("free-exercise-db")
  /// Soft ranking for AI candidate picking (higher = preferred)
  popularity       Int      @default(50)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([level])
  @@index([equipment])
  @@index([category])
  @@index([muscleGroup])
  @@index([source])
  @@index([name])
}

model Plan {
  id         String    @id @default(uuid())
  profile    Json
  splitType  String
  startDate  DateTime  @default(now())
  currentDay Int       @default(1)
  skeleton   Json
  createdAt  DateTime  @default(now())
  days       PlanDay[]
}

model PlanDay {
  id          String        @id @default(uuid())
  planId      String
  plan        Plan          @relation(fields: [planId], references: [id], onDelete: Cascade)
  dayNumber   Int
  weekNumber  Int
  focus       String
  isRestDay   Boolean       @default(false)
  status      PlanDayStatus @default(locked)
  workout     Json?
  generatedAt DateTime?
  completedAt DateTime?

  @@unique([planId, dayNumber])
  @@index([planId])
}
