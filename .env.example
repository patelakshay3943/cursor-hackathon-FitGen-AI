# =============================================================================
# FitGen AI — environment variables
# Copy to .env and fill in real values:  cp .env.example .env
# Never commit .env (it is gitignored).
# =============================================================================

# --- Database (required) -----------------------------------------------------
# Local Postgres (default port 5432):
DATABASE_URL=postgresql://fitgen:fitgen@localhost:5432/fitgen

# Docker Compose / embedded Postgres (host port 5433):
# DATABASE_URL=postgresql://fitgen:fitgen@localhost:5433/fitgen

# --- Cursor SDK (recommended) ------------------------------------------------
# Used for: Day N workout generation, live form coaching cues, session summary.
# Without a key, plan generation falls back to rule-based workouts and coaching
# uses rule-based cues only.
# Get a key: https://cursor.com/dashboard → Integrations
CURSOR_API_KEY=
CURSOR_MODEL=composer-2.5

# --- Exercise images ---------------------------------------------------------
# CDN base for free-exercise-db image paths stored in the Exercise table.
EXERCISE_IMAGE_BASE=https://raw.githubusercontent.com/yuhonas/free-exercise-db/main/exercises

# --- ElevenLabs TTS (optional) -----------------------------------------------
# Voice alerts when motion tracking detects wrong form.
# Without a key, coaching text still works; spoken audio is skipped.
# Get a key: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# Optional overrides (defaults: Rachel voice + flash model for low latency)
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# ELEVENLABS_MODEL_ID=eleven_flash_v2_5
